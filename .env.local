# ── Environment ───────────────────────────────────────────────
# Set to "production" in production to enable: JWT secret check, Alembic migrations
ENVIRONMENT=development

# ── Database ──────────────────────────────────────────────────
# For PostgreSQL (Docker / production):
# DATABASE_URL=postgresql+asyncpg://whatsapp:whatsapp_dev@localhost:5432/whatsapp_support
# For SQLite (local dev without Docker):
DATABASE_URL=sqlite+aiosqlite:///./support.db

# ── Docker PostgreSQL ─────────────────────────────────────────
POSTGRES_USER=whatsapp
POSTGRES_PASSWORD=whatsapp_dev
POSTGRES_DB=whatsapp_support

# ── JWT ───────────────────────────────────────────────────────
# CRITICAL: Change this in production! Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-in-production-use-a-long-random-string-0000000000000000
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# ── CORS ──────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── WhatsApp (Meta Cloud API) ─────────────────────────────────
# Get these from: Meta Developer Console → Your App → WhatsApp → API Setup
# System User permanent token (never expires if created via Business Manager)
WHATSAPP_
# Your company's main phone number ID (found in WhatsApp API Setup page)
WHATSAPP_COMPANY_PHONE_NUMBER_ID=1026848387180385
# WhatsApp Business Account ID (found in WhatsApp → Getting Started)
WHATSAPP_BUSINESS_ACCOUNT_ID=1635406751211494
# App Secret (found in App Dashboard → Settings → Basic → App Secret)
WHATSAPP_APP_SECRET=31d06664a5c4324466db9c96f3fad3a8
# Self-chosen string — must match what you enter in Meta webhook config
WHATSAPP_VERIFY_TOKEN=my-verify-token
# Meta Graph API version
WHATSAPP_API_VERSION=v18.0

# ── Next.js Frontend ─────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws
